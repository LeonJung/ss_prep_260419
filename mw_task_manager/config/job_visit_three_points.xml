<?xml version="1.0" encoding="UTF-8"?>
<!--
  Job: "VisitThreePoints"
  ============================

  Demonstrates Step-level orchestration with OUR control loop:
  the DriveToPose SubStep is implemented by mw_skill_library's
  drive_to_pose_server (direct /cmd_vel + /odom P-controller), NOT
  nav2's waypoint_follower or navigate_to_pose. Each waypoint visit
  is a separate BT action. Target coordinates are in /odom frame.

  Waypoints (fixed, 2026-04-17, relative to robot spawn pose):
    P1 = (1.0, 0.0,   0°)   forward 1 m
    P2 = (1.0, 1.0,  90°)   then turn-left 1 m
    P3 = (-1.0, 0.5, 180°)  then diagonal-back 2.2 m
-->
<root BTCPP_format="4">
  <BehaviorTree ID="VisitThreePoints">
    <Sequence name="Job_VisitThreePoints">
      <DriveToPose name="goto_p1"
                   target_x="1.0"  target_y="0.0"  target_yaw="0.0"/>
      <DriveToPose name="goto_p2"
                   target_x="1.0"  target_y="1.0"  target_yaw="1.5708"/>
      <DriveToPose name="goto_p3"
                   target_x="-1.0" target_y="0.5"  target_yaw="3.1416"/>
    </Sequence>
  </BehaviorTree>
</root>
